EMA_SWING_HOST=0.0.0.0
EMA_SWING_PORT=8080
EMA_SWING_APP_USERNAME=admin
EMA_SWING_APP_PASSWORD=change-this-password
EMA_SWING_SECRET_KEY=change-this-secret-key
EMA_SWING_LIVE_INSTANCE_DIR=/opt/ema-swing-live/instance

# auto keeps the existing Dhan/Yahoo behavior. Use icici after Breeze login/data tests pass.
ETF_DATA_PROVIDER=auto

# Optional: set these through the EC2 service environment instead of the UI.
ICICI_BREEZE_API_KEY=
ICICI_BREEZE_API_SECRET=
ICICI_BREEZE_SESSION_TOKEN=
