EMA_SWING_HOST=0.0.0.0
EMA_SWING_PORT=8080
EMA_SWING_APP_USERNAME=admin
EMA_SWING_APP_PASSWORD=change-this-password
EMA_SWING_SECRET_KEY=change-this-secret-key
EMA_SWING_LIVE_INSTANCE_DIR=/opt/ema-swing-live/instance
EMA_SWING_LIVE_DB_PATH=/opt/ema-swing-live/instance/ema_swing_live.sqlite

# Optional local-to-EC2 sync. Use the same token on EC2 and local.
EMA_SWING_REMOTE_URL=
EMA_SWING_SYNC_TOKEN=

# Optional lightweight EC2 broker gateway. Use this on local to proxy ICICI
# broker calls through EC2/static IP. Leave URL empty on EC2 itself.
EMA_SWING_BROKER_GATEWAY_URL=
EMA_SWING_BROKER_GATEWAY_TOKEN=
EMA_SWING_BROKER_GATEWAY_ICICI=1
EMA_SWING_BROKER_GATEWAY_DHAN_ORDERS=0

# auto keeps the existing Dhan/Yahoo behavior. Use icici after Breeze login/data tests pass.
ETF_DATA_PROVIDER=auto

# Optional: set these through the EC2 service environment instead of the UI.
ICICI_BREEZE_API_KEY=
ICICI_BREEZE_API_SECRET=
ICICI_BREEZE_SESSION_TOKEN=
